---
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const navLinks = [
  { href: "/approach", label: "Approach" },
  { href: "/services", label: "Services" },
  { href: "/writing", label: "Writing" },
  { href: "/about", label: "About" },
];

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header style="border-bottom: 1px solid var(--color-rule)">
  <div
    class="mx-auto w-full px-6 py-5 flex items-center justify-between"
    style="max-width: var(--measure-reading)"
  >
    <a
      href="/"
      class="text-xl font-semibold no-underline"
      style="font-family: var(--font-serif); color: var(--color-ink)"
    >
      Tutelare
    </a>
    <nav>
      <ul class="flex gap-6 text-sm m-0 p-0 list-none">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="no-underline"
                style={
                  isActive(link.href)
                    ? "color: var(--color-ink); font-weight: 500"
                    : "color: var(--color-ink-muted)"
                }
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
