---
import ContactStrip from "./ContactStrip.astro";

const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--color-rule)">
  <div class="mx-auto w-full px-6 py-10" style="max-width: var(--measure-reading)">
    <ContactStrip />
    <div
      class="mt-8 pt-6 text-xs flex flex-col gap-2 md:flex-row md:justify-between md:items-center"
      style="border-top: 1px solid var(--color-rule); color: var(--color-ink-muted)"
    >
      <p class="m-0">
        © {year} Tutelare. Content licensed under
        <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" rel="license">
          CC BY-NC-ND 4.0
        </a>.
      </p>
      <ul class="flex gap-4 m-0 p-0 list-none">
        <li><a href="/approach">Approach</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/writing">Writing</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/privacy">Privacy</a></li>
      </ul>
    </div>
  </div>
</footer>
