---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About"
  description="Tutelare is a boutique advisory practice led by Scott Thurlow. Founded 2026 in Bellevue, WA."
>
  <h1
    class="font-semibold leading-tight mb-6"
    style="font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem)"
  >
    About
  </h1>

  <section class="mb-10">
    <h2 class="text-xl font-semibold mb-3" style="font-family: var(--font-serif)">
      The practice
    </h2>
    <p>
      Tutelare is a boutique advisory practice founded in 2026. Currently solo-led from
      Bellevue, Washington, with engagements typically conducted remotely, occasionally
      on-site for assessment phases.
    </p>
  </section>

  <section class="mb-10">
    <h2 class="text-xl font-semibold mb-3" style="font-family: var(--font-serif)">
      Scott Thurlow
    </h2>
    <p>
      <em>Placeholder bio. Final About narrative to follow — pulling from the consulting
      resume and doctoral research, written as narrative rather than bullets.</em>
    </p>
  </section>

  <section class="mb-10 text-sm" style="color: var(--color-ink-muted)">
    <p>
      Tutelare is a practice operated by Teneo Group LLC. Contact:
      <a href="mailto:sthurlow@tutelare.ai">sthurlow@tutelare.ai</a>.
    </p>
  </section>
</BaseLayout>
